# ╔══════════════════════════════════════════════════════════════════╗
# ║                        uloggd — .env                             ║
# ║                                                                  ║
# ║  Copy this file as .env and fill in your credentials.           ║
# ║  Never commit the .env file to the repository.                  ║
# ╚══════════════════════════════════════════════════════════════════╝


# ─── App Base URL ──────────────────────────────────────────────────
# Base application URL (used for OAuth redirects and APIs)
# Examples:
# Dev: http://localhost:3000
# Prod: https://yoursite.com

APP_URL=


# ─── Steam API ─────────────────────────────────────────────────────
# Create your API key at: https://steamcommunity.com/dev/apikey
# Used to access public Steam data (profile, games, etc).

STEAM_WEB_API_KEY=


# ─── Twitch / IGDB ────────────────────────────────────────────────
# Create an application at https://dev.twitch.tv/console/apps
# These credentials are used to authenticate with the IGDB API.

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=


# ─── Supabase (Client) ───────────────────────────────────────────
# Variables exposed to the frontend (VITE_ prefix).
# Find at: Supabase Dashboard → Settings → API
# The anon key is public, but access is controlled by RLS.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=


# ─── Supabase (Server) ───────────────────────────────────────────
# Backend-only variables. NEVER expose the service role key.
# The service role key bypasses all RLS policies.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=


# ─── Imgchest ────────────────────────────────────────────────────
# Used for image uploads (banners, etc).
# Get your API key at https://imgchest.com/docs/api

IMGCHEST_API_KEY=


# ─── Discord ─────────────────────────────────────────────────────
# Webhook for team notifications (verification requests, etc).
# Create at: Discord → Channel → Edit Channel → Integrations → Webhooks

DISCORD_WEBHOOK_URL=


# ─── IsThereAnyDeal ──────────────────────────────────────────────
# Used for game price history.
# Create your API key at https://isthereanydeal.com/dev/app/

ISTHEREANYDEAL_API_KEY=


# ─── Dev.to ──────────────────────────────────────────────────────
# Used for blog/news posts.
# Create your API key at: Settings → Extensions → DEV Community API Keys

DEVTO_API_KEY=
